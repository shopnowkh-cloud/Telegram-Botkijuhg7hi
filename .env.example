# =========================================================
#  Copy this file to .env and fill in your values:
#    cp .env.example /opt/telegram-bot/.env
#    nano /opt/telegram-bot/.env
# =========================================================

# Required — Telegram credentials (from BotFather & my.telegram.org)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Required — Neon Postgres connection string
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional — loaded from DB if not set here (via admin panel ⚙️ Settings)
# BAKONG_TOKEN=your_bakong_jwt_token_here
